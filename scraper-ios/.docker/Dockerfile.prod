# AppStoreCat App Store Scraper — Production Image
# Multi-stage build: tsc compile -> node serve

FROM node:22-alpine AS build

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm ci

COPY . .
RUN npm run build

# --- Production ---
FROM node:22-alpine

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm ci --omit=dev

COPY --from=build /app/dist ./dist

EXPOSE ${PORT:-0}

CMD ["node", "dist/main.js"]
