APP_NAME=AppStoreCat
APP_ENV=local
APP_KEY=
APP_DEBUG=true

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=appstorecat-mysql
DB_PORT=3306
DB_DATABASE=appstorecat
DB_USERNAME=sail
DB_PASSWORD=password

# These are overridden by docker-compose environment
APP_URL=http://localhost:7460
FRONTEND_URL=http://localhost:7461
APPSTORE_API_URL=http://host.docker.internal:7462
GPLAY_API_URL=http://host.docker.internal:7463

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=appstorecat-redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log

# Swagger: set to false in production
L5_SWAGGER_GENERATE_ALWAYS=true

# Tracked app sync — how many apps dispatched per cron tick (every 20 minutes).
# Daily capacity per platform = value * 72. Default 5 = 360 apps/day.
SYNC_IOS_TRACKED_BATCH_SIZE=5
SYNC_ANDROID_TRACKED_BATCH_SIZE=5
