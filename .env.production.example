# AppStoreCat — Production Environment Variables
# Copy to .env and fill in all values

# ─── Ports ───────────────────────────────────────────────────
BACKEND_PORT=7460
FRONTEND_PORT=7461
APPSTORE_API_PORT=7462
GPLAY_API_PORT=7463
FORWARD_DB_PORT=7464

# ─── URLs ────────────────────────────────────────────────────
BACKEND_URL=http://localhost:7460
BACKEND_API_URL=http://localhost:7460/api/v1
FRONTEND_URL=http://localhost:7461
APPSTORE_API_URL=http://appstorecat-scraper-ios:7462
GPLAY_API_URL=http://appstorecat-scraper-android:7463

# ─── Database ────────────────────────────────────────────────
DB_DATABASE=appstorecat
DB_USERNAME=appstorecat
DB_PASSWORD=

# ─── Version ─────────────────────────────────────────────────
APP_VERSION=
