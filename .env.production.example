# AppStoreCat — Production Environment Variables
# Copy to .env and fill in all values

# ─── Ports ───────────────────────────────────────────────────
BACKEND_PORT=5500
FRONTEND_PORT=5501
APPSTORE_API_PORT=5502
GPLAY_API_PORT=5503
FORWARD_DB_PORT=5504

# ─── URLs ────────────────────────────────────────────────────
BACKEND_URL=http://localhost:5500
BACKEND_API_URL=http://localhost:5500/api/v1
FRONTEND_URL=http://localhost:5501
APPSTORE_API_URL=http://appstorecat-scraper-appstore:5502
GPLAY_API_URL=http://appstorecat-scraper-gplay:5503

# ─── Database ────────────────────────────────────────────────
DB_DATABASE=appstorecat
DB_USERNAME=appstorecat
DB_PASSWORD=

# ─── Version ─────────────────────────────────────────────────
APP_VERSION=
