# AppStoreCat — Development Environment Variables
# Copy to .env and fill in all values

# ─── Ports (746x series) ─────────────────────────────────────
BACKEND_PORT=7460
FRONTEND_PORT=7461
APPSTORE_API_PORT=7462
GPLAY_API_PORT=7463
FORWARD_DB_PORT=7464
FORWARD_REDIS_PORT=7465

# ─── URLs ────────────────────────────────────────────────────
BACKEND_URL=http://localhost:7460
FRONTEND_URL=http://localhost:7461
APPSTORE_API_URL=http://host.docker.internal:7462
GPLAY_API_URL=http://host.docker.internal:7463

# ─── Database ────────────────────────────────────────────────
DB_DATABASE=appstorecat
DB_USERNAME=sail
DB_PASSWORD=password

# ─── Analytics ───────────────────────────────────────────────
# Public Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
# Leave empty to disable analytics. Safe to expose (client-side ID).
GA_MEASUREMENT_ID=
